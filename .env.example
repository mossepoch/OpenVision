# OpenVision 环境变量示例
# 复制为 .env 并修改

# 数据库 (Docker 模式用 sqlite:////app/data/openvision.db)
DATABASE_URL=sqlite:///./openvision.db

# JWT 密钥 (生产环境务必修改!)
SECRET_KEY=change-me-in-production-use-random-string

# Token 有效期 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允许的前端地址 (逗号分隔)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://192.168.110.12:3001"]

# LLM (Claude) 配置
LLM_API_KEY=
LLM_BASE_URL=https://claude.mengzhaoxu.cn/claude

# 邮件告警推送 (可选，不配则不发邮件)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_TO=alert@yourcompany.com

# 飞书群机器人 webhook (可选)
# 在飞书群 → 设置 → 机器人 → 添加机器人 → 自定义机器人 → 获取 webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
